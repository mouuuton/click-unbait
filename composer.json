{
	"name": "freshrss/xextension-aititle",
	"description": "FreshRSS extension that automatically rewrites clickbait article titles using AI",
	"type": "freshrss-extension",
	"license": "GPL-3.0-or-later",
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"phpstan/phpstan": "^2.1"
	},
	"autoload": {
		"classmap": [
			"extension.php",
			"Controllers/"
		]
	},
	"autoload-dev": {
		"classmap": [
			"tests/stubs/"
		]
	}
}
