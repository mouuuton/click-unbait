	'ja' => 'Japanese (日本語)',
	'ko' => 'Korean (한국어)',
	'nl' => 'Dutch (Nederlands)',
	'pl' => 'Polish (Polski)',
	'pt-br' => 'Portuguese (Português)',
	'ru' => 'Russian (Русский)',
	'tr' => 'Turkish (Türkçe)',
	'zh-cn' => 'Chinese (中文)',
];
